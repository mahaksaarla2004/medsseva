generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String          @id @default(uuid())
  uhid                String?         @unique
  name                String
  email               String?         @unique
  mobile              String          @unique
  password            String?
  role                Role            @default(USER)
  avatarUrl           String?
  healthScore         Int             @default(0)
  createdAt           DateTime        @default(now())
  addresses           Address[]
  bookings            Booking[]
  familyMembers       Family[]
  paymentMethods      PaymentMethod[]
  verifiedReports     Report[]        @relation("ReportVerifier")
  paymentsReceived    Booking[]       @relation("PaymentReceiver")
  assignedCollections Booking[]       @relation("AssignedExecutive")
}

model City {
  id        String   @id @default(uuid())
  name      String   @unique
  icon      String   @default("city")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Address {
  id        String  @id @default(uuid())
  userId    String
  type      String
  line1     String
  line2     String?
  city      String
  state     String
  pincode   String
  isDefault Boolean @default(false)
  user      User    @relation(fields: [userId], references: [id])
}

model PaymentMethod {
  id        String   @id @default(uuid())
  userId    String
  bank      String
  last4     String
  holder    String
  expiry    String
  type      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Family {
  id       String @id @default(uuid())
  userId   String
  name     String
  relation String
  age      Int
  gender   String
  user     User   @relation(fields: [userId], references: [id])
}

model TestCategory {
  id       String  @id
  name     String
  iconName String
  isActive Boolean @default(true)
  tests    Test[]
}

model Test {
  id              String          @id @default(uuid())
  name            String
  description     String
  price           Float
  discountedPrice Float
  categoryId      String
  reportTime      String
  fastingRequired Boolean
  homeCollection  Boolean         @default(true)
  whyRequired     String?
  bookings        BookingTest[]
  packages        PackageTest[]
  category        TestCategory    @relation(fields: [categoryId], references: [id])
  parameters      TestParameter[]

  @@index([categoryId])
}

model TestParameter {
  id              String         @id @default(uuid())
  testId          String
  name            String
  unit            String
  referenceRanges Json
  isActive        Boolean        @default(true)
  reportResults   ReportResult[]
  test            Test           @relation(fields: [testId], references: [id], onDelete: Cascade)
}

model HealthPackage {
  id              String           @id @default(uuid())
  name            String
  subtitle        String?
  category        String           @default("General")
  categoryId      String           @default("general")
  description     String?
  price           Float
  oldPrice        Float
  discount        String?
  parametersCount Int
  badge           String?
  preparation     String?
  isActive        Boolean          @default(true)
  bookings        BookingPackage[]
  testsIncluded   PackageTest[]
}

model PackageTest {
  packageId String
  testId    String
  package   HealthPackage @relation(fields: [packageId], references: [id])
  test      Test          @relation(fields: [testId], references: [id])

  @@id([packageId, testId])
}

model Booking {
  id                   String              @id @default(cuid())
  userId               String
  scheduledDate        DateTime
  scheduledSlot        String
  totalPaid            Float
  status               BookingStatus       @default(PENDING)
  addressId            String
  patientName          String
  paymentId            String?
  razorpayOrderId      String?
  paymentStatus        PaymentStatus       @default(PENDING)
  collectionMode       CollectionMode      @default(HOME)
  paymentMode          PaymentMode?
  paymentReceivedAt    DateTime?
  paymentReceivedById  String?
  assignedExecutiveId  String?
  createdAt            DateTime            @default(now())
  user                 User                @relation(fields: [userId], references: [id])
  packages             BookingPackage[]
  tests                BookingTest[]
  report               Report?
  paymentReceivedBy    User?               @relation("PaymentReceiver", fields: [paymentReceivedById], references: [id])
  assignedExecutive    User?               @relation("AssignedExecutive", fields: [assignedExecutiveId], references: [id])
}

model BookingTest {
  bookingId String
  testId    String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  test      Test    @relation(fields: [testId], references: [id])

  @@id([bookingId, testId])
}

model BookingPackage {
  bookingId String
  packageId String
  booking   Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  package   HealthPackage @relation(fields: [packageId], references: [id])

  @@id([bookingId, packageId])
}

model Report {
  id               String         @id @default(uuid())
  bookingId        String         @unique
  testName         String
  reportedDate     DateTime       @default(now())
  status           ReportStatus   @default(DRAFT)
  clinicalNotes    String?
  hasAbnormalFlags Boolean        @default(false)
  verifiedById     String?
  verifiedAt       DateTime?
  booking          Booking        @relation(fields: [bookingId], references: [id])
  verifiedBy       User?          @relation("ReportVerifier", fields: [verifiedById], references: [id])
  parameters       ReportResult[]

  @@index([reportedDate])
}

model ReportResult {
  id             String         @id @default(uuid())
  reportId       String
  parameterId    String?
  parameterName  String
  observedValue  String
  unit           String
  referenceRange String
  isAbnormal     Boolean        @default(false)
  parameter      TestParameter? @relation(fields: [parameterId], references: [id])
  report         Report         @relation(fields: [reportId], references: [id])
}

enum Role {
  USER
  ADMIN
  PATHOLOGIST
  EXECUTIVE
}

enum CollectionMode {
  HOME
  LAB
}

enum PaymentMode {
  CASH
  UPI
  QR_CODE
  CARD
}
enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COLLECTED
  PROCESSING
  COMPLETED
  CANCELLED
}

enum ReportStatus {
  DRAFT
  UNDER_REVIEW
  RELEASED
}
